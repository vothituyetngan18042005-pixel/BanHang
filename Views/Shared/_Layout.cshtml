<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - ZôTreeStore</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #FBFBFC;
        }
    </style>
</head>

<body class="text-slate-900">

    <!-- NAVBAR -->
    <header class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-gray-100">

        <div class="container mx-auto px-6 h-20 flex justify-between items-center">

            <!-- Logo -->
            <a href="/"
               class="text-2xl font-extrabold text-blue-700 tracking-tight hover:text-blue-500 transition">
                ZôTreeStore
            </a>

            <!-- Menu -->
            <nav class="flex space-x-10 text-[13px] font-semibold uppercase tracking-widest text-gray-500">

                <a href="/Home/Index"
                   class="hover:text-blue-600 transition-colors">
                    Trang chủ
                </a>

                <a href="/Home/Laptop"
                   class="hover:text-blue-600 transition-colors">
                    Laptop
                </a>

                <a href="/Home/LinhKien"
                   class="hover:text-blue-600 transition-colors">
                    Linh kiện
                </a>

                <a href="/Home/PhuKien"
                   class="hover:text-blue-600 transition-colors">
                    Phụ kiện
                </a>

                <a href="/Home/Support"
                   class="hover:text-blue-600 transition-colors">
                    Hỗ trợ
                </a>

            </nav>

            <!-- Right -->
            <div class="flex items-center space-x-5">

                <!-- Search -->
                <div class="relative hidden md:block">

                    <input type="text"
                           placeholder="Tìm kiếm sản phẩm..."
                           class="bg-gray-100 rounded-full px-5 py-2 text-sm outline-none w-72">

                </div>

                <!-- Cart -->
                <button class="text-xl hover:text-blue-600">
                    🛒
                </button>

                <!-- User -->
                <div class="relative">

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <button id="userBtn"
                                class="text-xl hover:text-blue-600">
                            👤
                        </button>

                        <div id="userMenu"
                             class="hidden absolute right-0 mt-3 w-56 bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden z-50">

                            @if (User.IsInRole("Admin"))
                            {
                                <a href="/Product"
                                   class="block px-5 py-3 hover:bg-gray-50">
                                    📦 Quản lý sản phẩm
                                </a>

                                <a href="/Account/Settings"
                                   class="block px-5 py-3 hover:bg-gray-50">
                                    ⚙️ Cài đặt
                                </a>
                            }
                            else
                            {
                                <a href="/Account/Settings"
                                   class="block px-5 py-3 hover:bg-gray-50">
                                    👤 Hồ sơ
                                </a>
                            }

                            <a href="/Account/Logout"
                               class="block px-5 py-3 text-red-500 hover:bg-red-50">
                                🚪 Đăng xuất
                            </a>

                        </div>
                    }
                    else
                    {
                        <div class="flex items-center gap-3">

                            <a href="/Account/Login"
                               class="text-sm font-semibold hover:text-blue-600">
                                Đăng nhập
                            </a>

                            <a href="/Account/Register"
                               class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl text-sm font-semibold">
                                Đăng ký
                            </a>

                        </div>
                    }

                </div>

            </div>

        </div>

    </header>

    <!-- Nội dung -->
    <main>
        @RenderBody()
    </main>

    <script>

        const userBtn = document.getElementById("userBtn");
        const userMenu = document.getElementById("userMenu");

        if (userBtn) {

            userBtn.addEventListener("click", function (e) {

                e.stopPropagation();
                userMenu.classList.toggle("hidden");

            });

            document.addEventListener("click", function () {

                userMenu.classList.add("hidden");

            });

        }

    </script>
   

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>