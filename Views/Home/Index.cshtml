@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <title>ZôTreeStore - Định Nghĩa Lại Công Nghệ</title>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .hero-gradient {
            background: linear-gradient(90deg, #F8FAFC 0%, #EFF6FF 100%);
        }
    </style>
</head>
<body class="bg-[#FBFBFC] text-slate-900">

    <!-- NAVIGATION BAR -->
    <header class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-gray-100">
        <div class="container mx-auto px-6 h-20 flex justify-between items-center">
            <div class="text-2xl font-extrabold text-blue-700 tracking-tight">ZôTreeStore</div>

            <nav class="hidden lg:flex space-x-10 text-[13px] font-semibold uppercase tracking-widest text-gray-500">
                <a href="#" class="hover:text-blue-600 transition-colors">Laptop</a>
                <a href="#" class="hover:text-blue-600 transition-colors">Linh kiện</a>
                <a href="#" class="hover:text-blue-600 transition-colors">Phụ kiện</a>
                <a href="#" class="hover:text-blue-600 transition-colors">Hỗ trợ</a>
            </nav>

            <div class="flex items-center space-x-5">
                <div class="relative hidden md:block">
                    <input type="text" placeholder="Tìm kiếm sản phẩm..." class="bg-gray-100 rounded-full px-5 py-2 text-sm outline-none w-72 focus:ring-2 ring-blue-100 transition-all">
                    <span class="absolute right-4 top-2 text-gray-400">🔍</span>
                </div>
                <button class="text-xl hover:text-blue-600">🛒</button>
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="flex items-center gap-4">

                        <span class="text-sm font-semibold text-gray-700">
                            👋 @User.Identity.Name
                        </span>

                        <a asp-controller="Account"
                           asp-action="Logout"
                           class="bg-red-500 text-white px-4 py-2 rounded-xl text-sm hover:bg-red-600 transition">

                            Đăng xuất

                        </a>

                    </div>
                }
                else
                {
                    <div class="flex items-center gap-3">

                        <a asp-controller="Account"
                           asp-action="Login"
                           class="text-sm font-semibold hover:text-blue-600">

                            Đăng nhập

                        </a>

                        <a asp-controller="Account"
                           asp-action="Register"
                           class="bg-blue-600 text-white px-4 py-2 rounded-xl text-sm hover:bg-blue-700 transition">

                            Đăng ký

                        </a>

                    </div>
                }
            </div>
        </div>
    </header>

    <!-- HERO SECTION (Dựa trên image_57597d.png) -->
    <section class="hero-gradient overflow-hidden">
        <div class="container mx-auto px-6 py-20 flex flex-col lg:flex-row items-center">
            <div class="lg:w-1/2 space-y-8">
                <span class="inline-block bg-blue-700 text-white text-[11px] font-bold px-4 py-1.5 rounded-full uppercase tracking-tighter">
                    Mới ra mắt 2026
                </span>
                <h1 class="text-5xl lg:text-7xl font-bold leading-[1.1] text-slate-900">
                    Định Nghĩa Lại <br>
                    <span class="text-blue-600">Sức Mạnh</span> <br>
                    Công Nghệ
                </h1>
                <p class="text-gray-500 text-lg max-w-md leading-relaxed">
                    Trải nghiệm những dòng laptop và linh kiện hàng đầu với hiệu năng vượt trội, mang đến sự bứt phá trong mọi tác vụ chuyên nghiệp.
                </p>
            </div>
            <div class="lg:w-1/2 mt-12 lg:mt-0 relative">
                <!-- Thay thế src bằng ảnh laptop của bạn -->
                <div class="bg-white rounded-3xl p-4 shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-500">
                    <img src="/images/hero/trangchu.jpg"
                         alt="Hero Product"
                         class="rounded-2xl w-full">
                </div>
            </div>
        </div>
    </section>

    <!-- CATEGORIES (Dựa trên image_5755de.png) -->
    <section class="container mx-auto px-6 py-20 grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="group relative h-[320px] rounded-[2rem] overflow-hidden cursor-pointer shadow-xl">
            <img src="https://images.unsplash.com/photo-1603302576837-37561b2e2302?q=80&w=1000&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent p-8 flex flex-col justify-end">
                <h3 class="text-white text-2xl font-bold">Laptop</h3>
                <p class="text-gray-300 text-sm mt-1">Sức mạnh di động cho công việc</p>
                <span class="text-white mt-4 font-bold text-xs uppercase tracking-widest group-hover:translate-x-2 transition-transform">Khám phá →</span>
            </div>
        </div>
        <!-- Card 2 -->
        <div class="group relative h-[320px] rounded-[2rem] overflow-hidden cursor-pointer shadow-xl">
            <img src="https://images.unsplash.com/photo-1591799264318-7e6ef8ddb7ea?q=80&w=1000&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent p-8 flex flex-col justify-end">
                <h3 class="text-white text-2xl font-bold">Linh kiện</h3>
                <p class="text-gray-300 text-sm mt-1">Tối ưu hiệu suất dàn máy của bạn</p>
                <span class="text-white mt-4 font-bold text-xs uppercase tracking-widest group-hover:translate-x-2 transition-transform">Khám phá →</span>
            </div>
        </div>
        <!-- Card 3 -->
        <div class="group relative h-[320px] rounded-[2rem] overflow-hidden cursor-pointer shadow-xl">
            <img src="https://images.unsplash.com/photo-1544244015-0df4b3ffc6b0?q=80&w=1000&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent p-8 flex flex-col justify-end">
                <h3 class="text-white text-2xl font-bold">Phụ kiện</h3>
                <p class="text-gray-300 text-sm mt-1">Hoàn thiện hệ sinh thái công nghệ</p>
                <span class="text-white mt-4 font-bold text-xs uppercase tracking-widest group-hover:translate-x-2 transition-transform">Khám phá →</span>
            </div>
        </div>
    </section>

    <!-- PROMO BANNER (Dựa trên image_5759a0.jpg) -->
    <section class="container mx-auto px-6 py-10">
        <div class="bg-[#0057B7] rounded-[2.5rem] p-12 flex flex-col md:flex-row justify-between items-center text-white relative overflow-hidden">
            <div class="z-10 text-center md:text-left">
                <h2 class="text-4xl font-bold">Ưu Đãi Hè Rực Rỡ</h2>
                <p class="mt-4 text-blue-100 text-lg opacity-90">Giảm đến 15% cho tất cả các dòng phụ kiện cao cấp.<br>Nâng cấp trải nghiệm của bạn ngay hôm nay!</p>
            </div>
            <div class="mt-8 md:mt-0 z-10 bg-white/10 backdrop-blur-md border border-white/20 p-6 rounded-3xl text-center min-w-[200px]">
                <span class="block text-[10px] uppercase tracking-[0.2em] mb-1 font-bold">Mã giảm giá</span>
                <span class="text-3xl font-black tracking-widest">SUMMER15</span>
            </div>
            <!-- Decorative circles -->
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-blue-400/20 rounded-full"></div>
        </div>
    </section>

    <!-- SERVICE FEATURES -->
    <section class="container mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-10">
        <div class="flex items-start space-x-5">
            <div class="bg-blue-50 p-4 rounded-2xl text-2xl text-blue-600">🚚</div>
            <div>
                <h4 class="font-bold text-lg">Giao hàng 24h</h4>
                <p class="text-gray-500 text-sm mt-1">Nhận hàng siêu tốc trong vòng 24 giờ cho khu vực nội thành.</p>
            </div>
        </div>
        <div class="flex items-start space-x-5 border-x border-gray-100 px-10">
            <div class="bg-blue-50 p-4 rounded-2xl text-2xl text-blue-600">🛡️</div>
            <div>
                <h4 class="font-bold text-lg">Bảo hành chính hãng</h4>
                <p class="text-gray-500 text-sm mt-1">Cam kết 100% sản phẩm chính hãng với chính sách đổi trả linh hoạt.</p>
            </div>
        </div>
        <div class="flex items-start space-x-5">
            <div class="bg-blue-50 p-4 rounded-2xl text-2xl text-blue-600">🎧</div>
            <div>
                <h4 class="font-bold text-lg">Hỗ trợ 24/7</h4>
                <p class="text-gray-500 text-sm mt-1">Đội ngũ kỹ thuật viên giàu kinh nghiệm luôn sẵn sàng giải đáp.</p>
            </div>
        </div>
    </section>

    <!-- PRODUCT SLIDER -->
    <section class="container mx-auto px-6 py-10">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <!-- Product Item -->
            <div class="bg-white p-6 rounded-[2rem] shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-50 group">
                <div class="bg-gray-50 rounded-2xl mb-5 flex justify-center items-center h-52 overflow-hidden">
                    <img src="https://m.media-amazon.com/images/I/61fScaY16RL._AC_SL1500_.jpg" class="h-32 object-contain group-hover:scale-110 transition-transform">
                </div>
                <h3 class="font-bold text-lg">MacBook Pro M3 Max</h3>
                <div class="flex space-x-2 mt-2">
                    <span class="text-[10px] bg-blue-50 text-blue-600 px-2.5 py-1 rounded-full font-bold">14-inch</span>
                    <span class="text-[10px] bg-blue-50 text-blue-600 px-2.5 py-1 rounded-full font-bold">M3 Max</span>
                </div>
                <div class="flex justify-between items-center mt-8">
                    <span class="text-blue-700 font-extrabold text-xl">54.990.000đ</span>
                    <button class="bg-blue-50 p-3 rounded-2xl text-blue-600 hover:bg-blue-600 hover:text-white transition-colors">
                        🛒
                    </button>
                </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-50 group">
                <div class="bg-gray-50 rounded-2xl mb-5 flex justify-center items-center h-52 overflow-hidden">
                    <img src="https://m.media-amazon.com/images/I/61fScaY16RL._AC_SL1500_.jpg" class="h-32 object-contain group-hover:scale-110 transition-transform">
                </div>
                <h3 class="font-bold text-lg">MacBook Pro M3 Max</h3>
                <div class="flex space-x-2 mt-2">
                    <span class="text-[10px] bg-blue-50 text-blue-600 px-2.5 py-1 rounded-full font-bold">14-inch</span>
                    <span class="text-[10px] bg-blue-50 text-blue-600 px-2.5 py-1 rounded-full font-bold">M3 Max</span>
                </div>
                <div class="flex justify-between items-center mt-8">
                    <span class="text-blue-700 font-extrabold text-xl">54.990.000đ</span>
                    <button class="bg-blue-50 p-3 rounded-2xl text-blue-600 hover:bg-blue-600 hover:text-white transition-colors">
                        🛒
                    </button>
                </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-50 group">
                <div class="bg-gray-50 rounded-2xl mb-5 flex justify-center items-center h-52 overflow-hidden">
                    <img src="https://m.media-amazon.com/images/I/61fScaY16RL._AC_SL1500_.jpg" class="h-32 object-contain group-hover:scale-110 transition-transform">
                </div>
                <h3 class="font-bold text-lg">MacBook Pro M3 Max</h3>
                <div class="flex space-x-2 mt-2">
                    <span class="text-[10px] bg-blue-50 text-blue-600 px-2.5 py-1 rounded-full font-bold">14-inch</span>
                    <span class="text-[10px] bg-blue-50 text-blue-600 px-2.5 py-1 rounded-full font-bold">M3 Max</span>
                </div>
                <div class="flex justify-between items-center mt-8">
                    <span class="text-blue-700 font-extrabold text-xl">54.990.000đ</span>
                    <button class="bg-blue-50 p-3 rounded-2xl text-blue-600 hover:bg-blue-600 hover:text-white transition-colors">
                        🛒
                    </button>
                </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-50 group">
                <div class="bg-gray-50 rounded-2xl mb-5 flex justify-center items-center h-52 overflow-hidden">
                    <img src="https://m.media-amazon.com/images/I/61fScaY16RL._AC_SL1500_.jpg" class="h-32 object-contain group-hover:scale-110 transition-transform">
                </div>
                <h3 class="font-bold text-lg">MacBook Pro M3 Max</h3>
                <div class="flex space-x-2 mt-2">
                    <span class="text-[10px] bg-blue-50 text-blue-600 px-2.5 py-1 rounded-full font-bold">14-inch</span>
                    <span class="text-[10px] bg-blue-50 text-blue-600 px-2.5 py-1 rounded-full font-bold">M3 Max</span>
                </div>
                <div class="flex justify-between items-center mt-8">
                    <span class="text-blue-700 font-extrabold text-xl">54.990.000đ</span>
                    <button class="bg-blue-50 p-3 rounded-2xl text-blue-600 hover:bg-blue-600 hover:text-white transition-colors">
                        🛒
                    </button>
                </div>
            </div>
        </div>
    </section>

    

    <!-- FOOTER -->
    <footer class="bg-white pt-24 pb-12 border-t border-gray-100">
        <div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-16">
            <div class="col-span-1">
                <div class="text-2xl font-bold text-blue-700 mb-6">ZôTreeStore</div>
                <p class="text-gray-400 text-sm leading-relaxed mb-8">Silicon Serenity Architecture. Nền tảng cung cấp giải pháp công nghệ cao cấp hàng đầu Việt Nam.</p>
                <div class="flex space-x-4">
                    <div class="w-8 h-8 rounded-full border border-gray-100 flex items-center justify-center text-gray-400 hover:bg-blue-600 hover:text-white cursor-pointer">🌐</div>
                    <div class="w-8 h-8 rounded-full border border-gray-100 flex items-center justify-center text-gray-400 hover:bg-blue-600 hover:text-white cursor-pointer">✉️</div>
                </div>
            </div>
            <div>
                <h4 class="font-bold text-xs uppercase tracking-[0.2em] mb-8 text-gray-400">Liên kết</h4>
                <ul class="space-y-4 text-sm font-medium text-gray-600">
                    <li><a href="#" class="hover:text-blue-600">Về chúng tôi</a></li>
                    <li><a href="#" class="hover:text-blue-600">Chính sách bảo hành</a></li>
                    <li><a href="#" class="hover:text-blue-600">Điều khoản dịch vụ</a></li>
                </ul>
            </div>
            <div>
                <h4 class="font-bold text-xs uppercase tracking-[0.2em] mb-8 text-gray-400">Dịch vụ</h4>
                <ul class="space-y-4 text-sm font-medium text-gray-600">
                    <li><a href="#" class="hover:text-blue-600">Tạo yêu cầu</a></li>
                    <li><a href="#" class="hover:text-blue-600">Sửa chữa & nâng cấp</a></li>
                    <li><a href="#" class="hover:text-blue-600">Kiểm tra đơn hàng</a></li>
                </ul>
            </div>
            <div>
                <h4 class="font-bold text-xs uppercase tracking-[0.2em] mb-8 text-gray-400">Tài nguyên</h4>
                <ul class="space-y-4 text-sm font-medium text-gray-600">
                    <li><a href="#" class="hover:text-blue-600">Blog công nghệ</a></li>
                    <li><a href="#" class="hover:text-blue-600">Câu hỏi thường gặp</a></li>
                </ul>
            </div>
        </div>
        <div class="container mx-auto px-6 mt-20 pt-8 border-t border-gray-50 text-center text-gray-400 text-[10px] font-medium uppercase tracking-widest">
            © 2026 ZôTreeStore. Silicon Serenity Architecture.
        </div>
    </footer>

</body>
</html>