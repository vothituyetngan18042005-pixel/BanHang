@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZôTreeStore - Liên kết không hợp lệ</title>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #f4f6f9;
            padding: 20px;
        }

        .box {
            width: 100%;
            max-width: 420px;
            background: #fff;
            border-radius: 24px;
            padding: 40px;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        }

        i {
            font-size: 48px;
            color: #dc3545;
            margin-bottom: 15px;
        }

        h2 {
            color: #333;
            margin-bottom: 10px;
        }

        p {
            color: #777;
            font-size: 14px;
            line-height: 1.6;
            margin-bottom: 25px;
        }

        a.btn {
            display: inline-block;
            background: #0063a7;
            color: #fff;
            text-decoration: none;
            padding: 14px 28px;
            border-radius: 14px;
            font-weight: 700;
            font-size: 14px;
        }

            a.btn:hover {
                background: #004d84;
            }
    </style>
</head>
<body>
    <div class="box">
        <i class='bx bx-error-circle'></i>
        <h2>Liên kết không hợp lệ</h2>
        <p>@(ViewBag.Error ?? "Liên kết đặt lại mật khẩu không tồn tại hoặc đã hết hạn. Vui lòng yêu cầu lại.")</p>
        <a href="/Account/ForgotPassword" class="btn">Yêu cầu lại</a>
    </div>
</body>
</html>