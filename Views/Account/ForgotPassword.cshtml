@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZôTreeStore - Quên mật khẩu</title>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #f4f6f9;
            padding: 20px;
        }

        .forgot-container {
            width: 100%;
            max-width: 450px;
            background: #fff;
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        }

        .logo {
            display: block;
            text-align: center;
            font-size: 32px;
            font-weight: 700;
            color: #0063a7;
            text-decoration: none;
            margin-bottom: 25px;
        }

        .title {
            text-align: center;
            font-size: 28px;
            font-weight: 700;
            color: #333;
            margin-bottom: 10px;
        }

        .desc {
            text-align: center;
            color: #777;
            font-size: 14px;
            line-height: 1.6;
            margin-bottom: 30px;
        }

        .alert-success {
            background: #e7fff0;
            color: #198754;
            padding: 14px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .alert-error {
            background: #ffe5e5;
            color: #dc3545;
            padding: 14px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .alert-demo {
            background: #fff8e5;
            color: #8a6100;
            padding: 14px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 13px;
            word-break: break-all;
        }

            .alert-demo a {
                color: #0063a7;
                font-weight: 700;
            }

        .form-group {
            margin-bottom: 20px;
        }

            .form-group label {
                display: block;
                margin-bottom: 8px;
                font-size: 13px;
                font-weight: 700;
                text-transform: uppercase;
                color: #333;
            }

        .input-wrapper {
            position: relative;
        }

            .input-wrapper i {
                position: absolute;
                left: 16px;
                top: 50%;
                transform: translateY(-50%);
                color: #999;
                font-size: 18px;
            }

        .form-control {
            width: 100%;
            padding: 15px 15px 15px 48px;
            border: 1px solid #ddd;
            border-radius: 14px;
            outline: none;
            background: #f8f9fa;
            font-size: 15px;
            transition: 0.3s;
        }

            .form-control:focus {
                border-color: #0063a7;
                background: #fff;
                box-shadow: 0 0 0 4px rgba(0,99,167,0.08);
            }

        .btn-submit {
            width: 100%;
            border: none;
            background: #0063a7;
            color: #fff;
            padding: 15px;
            border-radius: 14px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 10px;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .btn-submit:hover {
                background: #004d84;
            }

        .back-link {
            margin-top: 22px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 5px;
            text-decoration: none;
            color: #0063a7;
            font-weight: 600;
            font-size: 14px;
        }

            .back-link:hover {
                text-decoration: underline;
            }

        @@media(max-width: 500px) {
            .forgot-container {
                padding: 30px 22px;
            }

            .title {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>
    <div class="forgot-container">
        <a href="/" class="logo">ZôTreeStore</a>
        <div class="title">Quên mật khẩu</div>
        <div class="desc">Nhập Email hoặc số điện thoại để khôi phục tài khoản của bạn.</div>

        @if (ViewBag.Success != null)
        {
            <div class="alert-success">@ViewBag.Success</div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="alert-error">@ViewBag.Error</div>
        }

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Email hoặc Số điện thoại</label>
                <div class="input-wrapper">
                    <i class='bx bx-at'></i>
                    <input type="text" name="identity" class="form-control"
                           placeholder="example@gmail.com hoặc 0901234567" required />
                </div>
            </div>

            <button type="submit" class="btn-submit">
                Gửi mã khôi phục
                <i class='bx bx-paper-plane'></i>
            </button>

            <a href="/Account/Login" class="back-link">
                <i class='bx bx-left-arrow-alt'></i>
                Quay lại Đăng nhập
            </a>
        </form>
    </div>
</body>
</html>