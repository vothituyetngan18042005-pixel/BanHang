@model List<BanHang.Models.Product>
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <title>ZôTreeStore - Phụ kiện Bàn phím Logitech</title>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #FBFBFC;
        }

        .hero-gradient {
            background: linear-gradient(135deg, #EFF4FF 0%, #FDF4F8 100%);
        }
    </style>
</head>
<body class="text-slate-900">

    

    <section class="container mx-auto px-12 my-8">
        <div class="hero-gradient rounded-[2.5rem] p-12 flex flex-col md:flex-row items-center justify-between relative overflow-hidden">
            <div class="md:w-1/2 space-y-4 max-w-lg z-10">
                <span class="text-[10px] bg-blue-600 text-white font-bold tracking-wider px-3 py-1 rounded-full uppercase">Bộ sưu tập 2024</span>
                <h1 class="text-4xl font-extrabold text-slate-900 leading-tight pt-2">Nâng tầm trải<br>nghiệm</h1>
                <p class="text-slate-500 text-xs leading-relaxed max-w-sm">Khám phá bộ sưu tập phụ kiện gaming và văn phòng đỉnh cao, được thiết kế cho sự chính xác và thoải mái tuyệt đối.</p>
            </div>
            <div class="md:w-1/2 flex justify-end z-10">
                <div class="bg-white/40 p-4 rounded-3xl backdrop-blur-md shadow-xl shadow-blue-900/5 max-w-md">
                    <img src="https://images.unsplash.com/photo-1587829741301-dc798b83add3?q=80&w=600&auto=format&fit=crop" alt="Accessories Setup" class="rounded-2xl object-cover w-full h-52">
                </div>
            </div>
        </div>
    </section>

    <main class="container mx-auto px-12 py-8 flex flex-col md:flex-row gap-12">

        <aside class="w-full md:w-1/5 space-y-8">
            <div>
                <h4 class="font-bold text-[11px] uppercase tracking-[0.1em] mb-4 text-slate-900 flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                    Loại phụ kiện
                </h4>
                <div class="space-y-3 text-xs font-semibold text-slate-600">
                    <label class="flex items-center space-x-3 cursor-pointer">
                        <input type="checkbox" checked class="w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-0">
                        <span class="text-blue-600">Bàn phím</span>
                    </label>
                    <label class="flex items-center space-x-3 cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 rounded border-gray-300 focus:ring-0">
                        <span>Chuột</span>
                    </label>
                    <label class="flex items-center space-x-3 cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 rounded border-gray-300 focus:ring-0">
                        <span>Tai nghe</span>
                    </label>
                </div>
            </div>

            <div>
                <h4 class="font-bold text-[11px] uppercase tracking-[0.1em] mb-4 text-slate-900 flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                    Thương hiệu
                </h4>
                <div class="flex gap-2">
                    <button class="bg-blue-600 text-white px-5 py-1.5 rounded-lg text-[10px] font-bold shadow-sm">Logitech</button>
                    <button class="border border-gray-200 text-slate-700 px-5 py-1.5 rounded-lg text-[10px] font-bold hover:bg-gray-50 bg-white">Razer</button>
                </div>
            </div>
        </aside>

        <section class="flex-1">
            <h2 class="text-lg font-bold mb-6 text-slate-900">Danh sách sản phẩm</h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

                @foreach (var item in Model)
                {
                    <div class="bg-white p-5 rounded-[1.8rem] border border-slate-100 shadow-sm hover:shadow-md transition-all duration-300 flex flex-col justify-between">
                        <div>
                            <div class="rounded-2xl h-44 flex items-center justify-center mb-4 overflow-hidden bg-white">
                                <img src="@item.ImageUrl" class="h-32 object-contain hover:scale-105 transition-transform duration-300" alt="@item.Name">
                            </div>

                            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-wider block mb-1">
                                Gaming Gear
                            </span>

                            <h3 class="font-bold text-xs text-slate-800 leading-snug min-h-[32px] hover:text-blue-600 transition">
                                @item.Name
                            </h3>
                        </div>

                        <div class="flex justify-between items-center mt-6">
                            <span class="text-blue-600 font-extrabold text-[13px]">
                                @item.Price.ToString("N0") VNĐ
                            </span>
                            <button class="bg-blue-50 hover:bg-blue-100 text-blue-600 w-8 h-8 rounded-xl flex items-center justify-center transition">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                            </button>
                        </div>
                    </div>
                }

            </div>

            <div class="flex items-center justify-center space-x-2 mt-12">
                <button class="w-7 h-7 flex items-center justify-center rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50 text-xs">‹</button>
                <button class="w-7 h-7 flex items-center justify-center rounded-lg bg-blue-600 text-white font-bold text-xs">1</button>
                <button class="w-7 h-7 flex items-center justify-center rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50 text-xs">2</button>
                <button class="w-7 h-7 flex items-center justify-center rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50 text-xs">3</button>
                <span class="text-slate-400 text-xs px-1">...</span>
                <button class="w-7 h-7 flex items-center justify-center rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50 text-xs">›</button>
            </div>

        </section>
    </main>

    <footer class="bg-white border-t border-slate-100 mt-20 text-[11px] text-slate-500 py-12">
        <div class="container mx-auto px-12 grid grid-cols-1 md:grid-cols-4 gap-8">
            <div class="space-y-3">
                <h3 class="text-sm font-extrabold text-slate-800">ZôTreeStore</h3>
                <p class="leading-relaxed">Silicon Serenity Architecture.<br>Nền tảng cung cấp giải pháp công nghệ cao hàng đầu Việt Nam.</p>
                <div class="flex space-x-3 text-slate-400 pt-2">
                    <a href="#" class="hover:text-blue-600"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.53c-.26-.81-1-1.4-1.9-1.4h-1v-3c0-.55-.45-1-1-1h-6v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" /></svg></a>
                    <a href="#" class="hover:text-blue-600"><svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" /></svg></a>
                    <a href="#" class="hover:text-blue-600"><svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg></a>
                </div>
            </div>
            <div class="space-y-2.5">
                <h4 class="font-bold text-slate-800 uppercase tracking-wider">Liên kết</h4>
                <ul class="space-y-2">
                    <li><a href="#" class="hover:text-blue-600">Về chúng tôi</a></li>
                    <li><a href="#" class="hover:text-blue-600">Chính sách bảo hành</a></li>
                    <li><a href="#" class="hover:text-blue-600">Điều khoản dịch vụ</a></li>
                    <li><a href="#" class="hover:text-blue-600">Liên hệ hỗ trợ</a></li>
                </ul>
            </div>
            <div class="space-y-2.5">
                <h4 class="font-bold text-slate-800 uppercase tracking-wider">Dịch vụ</h4>
                <ul class="space-y-2">
                    <li><a href="#" class="hover:text-blue-600">Tạo yêu cầu</a></li>
                    <li><a href="#" class="hover:text-blue-600">Sửa chữa & nâng cấp</a></li>
                    <li><a href="#" class="hover:text-blue-600">Kiểm tra đơn hàng</a></li>
                </ul>
            </div>
            <div class="space-y-2.5">
                <h4 class="font-bold text-slate-800 uppercase tracking-wider">Tài nguyên</h4>
                <ul class="space-y-2">
                    <li><a href="#" class="hover:text-blue-600">Blog công nghệ</a></li>
                    <li><a href="#" class="hover:text-blue-600">Hướng dẫn sử dụng sản phẩm</a></li>
                    <li><a href="#" class="hover:text-blue-600">Câu hỏi thường gặp</a></li>
                    <li><a href="#" class="hover:text-blue-600">Trung tâm hỗ trợ</a></li>
                </ul>
            </div>
        </div>
        <div class="container mx-auto px-12 mt-12 pt-6 border-t border-slate-100 text-center text-slate-400 text-[10px]">
            © 2026 ZôTreeStore. Silicon Serenity Architecture.
        </div>
    </footer>

</body>
</html>