@model List<BanHang.Models.Product>

@{
    ViewData["Title"] = "Phụ kiện";
    Layout = "_Layout";

    var selectedAccessoryTypes = ViewBag.SelectedAccessoryTypes as string[] ?? Array.Empty<string>();
    var selectedBrands = ViewBag.SelectedBrands as string[] ?? Array.Empty<string>();
}

<!-- HERO -->
<section class="container mx-auto px-12 my-8">
    <div class="bg-gradient-to-r from-blue-100 to-pink-100 rounded-3xl p-12 flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold">Phụ kiện công nghệ</h1>
            <p class="text-gray-500 text-sm">Chuột - Bàn phím - Tai nghe - Loa</p>
        </div>
    </div>
</section>

<!-- MAIN -->
<main class="container mx-auto px-10 py-10 flex gap-10">

    <!-- FILTER -->
    <aside class="w-1/5">

        <form asp-action="PhuKien" asp-controller="Home" method="get">

            <!-- LOẠI -->
            <h4 class="font-bold text-sm mb-3">Loại phụ kiện</h4>

            <label>
                <input type="checkbox"
                       name="accessoryType"
                       value="BanPhim"
                       onchange="this.form.submit()"
                       @(selectedAccessoryTypes.Contains("BanPhim") ? "checked" : "") />
                Bàn phím
            </label>
            <br />

            <label>
                <input type="checkbox"
                       name="accessoryType"
                       value="Chuot"
                       onchange="this.form.submit()"
                       @(selectedAccessoryTypes.Contains("Chuot") ? "checked" : "") />
                Chuột
            </label>
            <br />

            <label>
                <input type="checkbox"
                       name="accessoryType"
                       value="TaiNghe"
                       onchange="this.form.submit()"
                       @(selectedAccessoryTypes.Contains("TaiNghe") ? "checked" : "") />
                Tai nghe
            </label>
            <br />

            <label>
                <input type="checkbox"
                       name="accessoryType"
                       value="Loa"
                       onchange="this.form.submit()"
                       @(selectedAccessoryTypes.Contains("Loa") ? "checked" : "") />
                Loa
            </label>

            <hr class="my-4" />

            <!-- HÃNG -->
            <h4 class="font-bold text-sm mb-3">Thương hiệu</h4>

            <label>
                <input type="checkbox"
                       name="brand"
                       value="Logitech"
                       onchange="this.form.submit()"
                       @(selectedBrands.Contains("Logitech") ? "checked" : "") />
                Logitech
            </label>
            <br />

            <label>
                <input type="checkbox"
                       name="brand"
                       value="Razer"
                       onchange="this.form.submit()"
                       @(selectedBrands.Contains("Razer") ? "checked" : "") />
                Razer
            </label>

        </form>

    </aside>

    <!-- PRODUCTS -->
    <section class="flex-1">

        <h2 class="text-xl font-bold mb-5">Danh sách phụ kiện</h2>

        <div class="grid grid-cols-3 gap-6">

            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="bg-white p-4 rounded-xl shadow">

                        <img src="@item.ImageUrl" class="h-32 mx-auto" />

                        <h3 class="font-bold mt-2">@item.Name</h3>

                        <p class="text-blue-600 font-bold">
                            @item.Price.ToString("N0") đ
                        </p>

                        <p class="text-xs text-gray-400">
                            @item.Brand - @item.AccessoryType
                        </p>

                    </div>
                }
            }
            else
            {
                <p>Không có sản phẩm phù hợp</p>
            }

        </div>

    </section>

</main>