@model List<BanHang.Models.Product>
@{
    var selectedBrand = ViewBag.SelectedBrand as string[] ?? Array.Empty<string>();
    var selectedRam = ViewBag.SelectedRam as int[] ?? Array.Empty<int>();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <title>ZôTreeStore - Danh sách sản phẩm</title>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #FBFBFC;
        }

        .hero-gradient {
            background: linear-gradient(135deg, #E0E7FF 0%, #FDF2F8 100%);
        }
    </style>
</head>
<body class="text-slate-900">

   
    <!-- HERO SECTION -->
    <section class="hero-gradient py-16 overflow-hidden">
        <div class="container mx-auto px-6 flex flex-col md:flex-row items-center justify-between">
            <div class="md:w-1/2 space-y-6">
                <span class="inline-block bg-blue-600 text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase">New Arrival 2024</span>
                <h1 class="text-5xl font-extrabold text-slate-800 leading-[1.1]">Định Nghĩa Lại<br>Sức Mạnh Công Nghệ.</h1>
                <p class="text-gray-500 text-sm max-w-sm leading-relaxed">Trải nghiệm những dòng laptop cao cấp nhất với hiệu năng vượt trội và thiết kế tinh xảo, kiến tạo tương lai của bạn.</p>
            </div>
            <div class="md:w-1/3 mt-10 md:mt-0 relative">
                <div class="bg-white/40 p-6 rounded-[2.5rem] backdrop-blur-md shadow-2xl shadow-blue-100">
                    <img src="https://images.unsplash.com/photo-1517336712468-0776482cb068?q=80&w=800&auto=format&fit=crop" alt="Laptop Hero" class="rounded-2xl">
                </div>
            </div>
        </div>
    </section>

    <!-- MAIN CONTENT -->
    <main class="container mx-auto px-6 py-16 flex flex-col md:flex-row gap-12">

        <!-- SIDEBAR FILTER -->
        <aside class="w-full md:w-1/5 space-y-10">

            <form asp-action="Laptop" asp-controller="Home" method="get" id="filterForm">

                <!-- THƯƠNG HIỆU -->
                <div>
                    <h4 class="font-bold text-[11px] uppercase tracking-[0.2em] mb-5 text-slate-400">
                        THƯƠNG HIỆU
                    </h4>

                    <div class="space-y-3 text-sm font-medium text-slate-600">

                        <label class="flex items-center space-x-3 cursor-pointer">
                            <input type="checkbox"
                                   name="brand"
                                   value="Apple"
                                   onchange="this.form.submit()"
                                   @(selectedBrand.Contains("Apple") ? "checked" : "") />
                            <span>Apple</span>
                        </label>

                        <label class="flex items-center space-x-3 cursor-pointer">
                            <input type="checkbox"
                                   name="brand"
                                   value="Dell"
                                   onchange="this.form.submit()"
                                   @(selectedBrand.Contains("Dell") ? "checked" : "") />
                            <span>Dell</span>
                        </label>

                        <label class="flex items-center space-x-3 cursor-pointer">
                            <input type="checkbox"
                                   name="brand"
                                   value="HP"
                                   onchange="this.form.submit()"
                                   @(selectedBrand.Contains("HP") ? "checked" : "") />
                            <span>HP</span>
                        </label>

                        <label class="flex items-center space-x-3 cursor-pointer">
                            <input type="checkbox"
                                   name="brand"
                                   value="ASUS"
                                   onchange="this.form.submit()"
                                   @(selectedBrand.Contains("ASUS") ? "checked" : "") />
                            <span>ASUS</span>
                        </label>

                    </div>
                </div>

                <!-- RAM -->
                <div>
                    <h4 class="font-bold text-[11px] uppercase tracking-[0.2em] mb-5 text-slate-400">
                        RAM
                    </h4>

                    <div class="space-y-3 text-sm font-medium text-slate-600">

                        <label class="flex items-center space-x-3 cursor-pointer">
                            <input type="checkbox"
                                   name="ram"
                                   value="8"
                                   onchange="this.form.submit()"
                                   @(selectedRam.Contains(8) ? "checked" : "") />
                            <span>8 GB</span>
                        </label>

                        <label class="flex items-center space-x-3 cursor-pointer">
                            <input type="checkbox"
                                   name="ram"
                                   value="16"
                                   onchange="this.form.submit()"
                                   @(selectedRam.Contains(16) ? "checked" : "") />
                            <span>16 GB</span>
                        </label>

                        <label class="flex items-center space-x-3 cursor-pointer">
                            <input type="checkbox"
                                   name="ram"
                                   value="32"
                                   onchange="this.form.submit()"
                                   @(selectedRam.Contains(32) ? "checked" : "") />
                            <span>32 GB</span>
                        </label>

                        <label class="flex items-center space-x-3 cursor-pointer">
                            <input type="checkbox"
                                   name="ram"
                                   value="64"
                                   onchange="this.form.submit()"
                                   @(selectedRam.Contains(64) ? "checked" : "") />
                            <span>64 GB</span>
                        </label>

                    </div>
                </div>

                @if (selectedBrand.Any() || selectedRam.Any())
                {
                    <a asp-action="Laptop"
                       asp-controller="Home"
                       class="inline-block mt-5 text-blue-600 text-sm font-semibold hover:underline">
                        ✕ Xóa bộ lọc
                    </a>
                }

            </form>

        </aside>

        <!-- PRODUCT GRID -->
        <section class="flex-1">
            <h2 class="text-xl font-extrabold mb-10 text-slate-800">Danh sách sản phẩm</h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">

                @foreach (var item in Model)
                {
                    <div class="group cursor-pointer">

                        <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-gray-50 hover:shadow-xl transition-all duration-300">

                            <div class="bg-slate-50 rounded-2xl h-48 flex items-center justify-center mb-6 overflow-hidden">

                                <img src="@item.ImageUrl"
                                     class="h-32 object-contain group-hover:scale-110 transition-transform"
                                     alt="@item.Name">

                            </div>

                            <h3 class="font-bold text-sm text-slate-800">
                                @item.Name
                            </h3>

                            <div class="flex justify-between items-center mt-8">

                                <span class="text-blue-700 font-extrabold text-base">
                                    @item.Price.ToString("N0") đ
                                </span>

                                <button class="bg-blue-50 p-2.5 rounded-xl text-blue-600">
                                    🛒
                                </button>

                            </div>

                        </div>

                    </div>
                }

            </div>
    </footer>

</body>
</html>