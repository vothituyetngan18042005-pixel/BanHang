@model BanHang.Models.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Xóa sản phẩm</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter',sans-serif;
            background: #f8fafc;
        }
    </style>

</head>

<body>

    <div class="min-h-screen flex justify-center items-center">

        <div class="bg-white w-[500px] rounded-3xl shadow-xl p-10">

            <h2 class="text-3xl font-bold text-red-600 mb-5">
                Xóa sản phẩm
            </h2>

            <p class="text-gray-600 mb-8">
                Bạn có chắc chắn muốn xóa sản phẩm này không?
            </p>

            <div class="border rounded-2xl p-5 bg-gray-50">

                <img src="@Model.ImageUrl"
                     class="w-36 h-36 mx-auto rounded-xl object-cover mb-5">

                <h3 class="text-xl font-bold text-center">
                    @Model.Name
                </h3>

                <p class="text-center text-red-600 font-bold mt-2">
                    @Model.Price.ToString("N0") đ
                </p>

            </div>

            <form asp-action="Delete" class="mt-8">

                <input asp-for="Id" hidden />

                <div class="flex justify-end gap-3">

                    <a asp-action="Index"
                       class="px-6 py-3 bg-gray-300 rounded-xl">

                        Hủy

                    </a>

                    <button type="submit"
                            class="px-6 py-3 bg-red-600 hover:bg-red-700 text-white rounded-xl">

                        Xóa

                    </button>

                </div>

            </form>

        </div>

    </div>

</body>
</html>