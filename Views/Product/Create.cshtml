@model BanHang.Models.Product

@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thêm sản phẩm - ZôTreeStore</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter',sans-serif;
            background: linear-gradient(135deg,#e0f2fe,#f8fafc,#ffffff);
        }
    </style>

</head>

<body>

    <div class="min-h-screen flex justify-center items-center p-10">

        <div class="bg-white w-full max-w-3xl rounded-3xl shadow-2xl p-10">

            <h1 class="text-3xl font-bold text-blue-700 mb-2">
                Thêm sản phẩm
            </h1>

            <p class="text-gray-500 mb-8">
                Nhập thông tin sản phẩm mới vào hệ thống.
            </p>

            <form asp-action="Create" method="post">

                <div class="grid grid-cols-2 gap-6">

                    <!-- Tên -->
                    <div class="col-span-2">

                        <label class="font-semibold text-gray-700">
                            Tên sản phẩm
                        </label>

                        <input asp-for="Name"
                               class="mt-2 w-full border rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none">

                        <span asp-validation-for="Name"
                              class="text-red-500 text-sm"></span>

                    </div>

                    <!-- Giá -->
                    <div>

                        <label class="font-semibold text-gray-700">
                            Giá
                        </label>

                        <input asp-for="Price"
                               class="mt-2 w-full border rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none">

                        <span asp-validation-for="Price"
                              class="text-red-500 text-sm"></span>

                    </div>
                    <!-- Loại sản phẩm -->
                    <div>

                        <label class="font-semibold text-gray-700">
                            Loại sản phẩm
                        </label>

                        <select asp-for="Category"
                                id="category"
                                class="mt-2 w-full border rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none">

                            <option value="Laptop">Laptop</option>
                            <option value="LinhKien">Linh kiện</option>
                            <option value="PhuKien">Phụ kiện</option>

                        </select>

                    </div>
                    <!-- Hãng -->
                    <div id="brandBox">

                        <label class="font-semibold text-gray-700">
                            Hãng
                        </label>

                        <select asp-for="Brand"
                                id="brand"
                                class="mt-2 w-full border rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none">

                            <option value="">-- Chọn hãng --</option>
                            
                        </select>

                    </div>

                    <!-- Ảnh -->
                    <div>

                        <label class="font-semibold text-gray-700">
                            Link hình ảnh
                        </label>

                        <input asp-for="ImageUrl"
                               class="mt-2 w-full border rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none">

                    </div>
                    <!-- RAM -->
                    <div id="ramBox">

                        <label class="font-semibold text-gray-700">
                            RAM
                        </label>

                        <select asp-for="Ram"
                                class="mt-2 w-full border rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none">

                            <option value="">-- Chọn RAM --</option>
                            <option value="8">8 GB</option>
                            <option value="16">16 GB</option>
                            <option value="32">32 GB</option>
                            <option value="64">64 GB</option>

                        </select>

                    </div>
                    <!-- LINH KIỆN -->
                    <div id="typeBox">

                        <label class="font-semibold text-gray-700">
                            Loại linh kiện
                        </label>

                        <select asp-for="Type"
                                class="mt-2 w-full border rounded-xl px-4 py-3">

                            <option value="">-- Chọn --</option>
                            <option value="RAM">RAM</option>
                            <option value="SSD">SSD</option>
                            <option value="CPU">CPU</option>
                            <option value="GPU">GPU</option>

                        </select>

                    </div>
                    <!-- PHỤ KIỆN -->
                    <div id="accessoryBox">

                        <label class="font-semibold text-gray-700">
                            Loại phụ kiện
                        </label>

                        <select asp-for="AccessoryType"
                                class="mt-2 w-full border rounded-xl px-4 py-3">

                            <option value="">-- Chọn --</option>
                            <option value="Chuot">Chuột</option>
                            <option value="BanPhim">Bàn phím</option>
                            <option value="TaiNghe">Tai nghe</option>
                            <option value="Loa">Loa</option>

                        </select>

                    </div>

                    <!-- Mô tả -->
                    <div class="col-span-2">

                        <label class="font-semibold text-gray-700">
                            Mô tả
                        </label>

                        <textarea asp-for="Description"
                                  rows="5"
                                  class="mt-2 w-full border rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none"></textarea>

                    </div>

                </div>

                <div class="flex justify-end gap-4 mt-8">

                    <a asp-action="Index"
                       class="px-6 py-3 rounded-xl bg-gray-200 hover:bg-gray-300">

                        Quay lại

                    </a>

                    <button type="submit"
                            class="px-8 py-3 rounded-xl bg-blue-600 text-white hover:bg-blue-700 transition">

                        Thêm sản phẩm

                    </button>

                </div>

            </form>

        </div>

    </div>
    <script>

        const category = document.getElementById("category");

        const brandBox = document.getElementById("brandBox");
        const ramBox = document.getElementById("ramBox");
        const typeBox = document.getElementById("typeBox");
        const accessoryBox = document.getElementById("accessoryBox");

                function showFields() {

            const brand = document.getElementById("brand");

            if (category.value == "Laptop") {

                brandBox.style.display = "block";
                ramBox.style.display = "block";
                typeBox.style.display = "none";
                accessoryBox.style.display = "none";

                brand.innerHTML = `
                    <option value="">-- Chọn hãng --</option>
                    <option value="Apple">Apple</option>
                    <option value="ASUS">ASUS</option>
                    <option value="Acer">Acer</option>
                    <option value="Dell">Dell</option>
                    <option value="HP">HP</option>
                    <option value="Lenovo">Lenovo</option>
                    <option value="MSI">MSI</option>
                `;
            }

            else if (category.value == "LinhKien") {

                brandBox.style.display = "block";
                ramBox.style.display = "none";
                typeBox.style.display = "block";
                accessoryBox.style.display = "none";

                brand.innerHTML = `
                    <option value="">-- Chọn hãng --</option>
                    <option value="Kingston">Kingston</option>
                    <option value="Samsung">Samsung</option>
                    
                `;
            }

            else if (category.value == "PhuKien") {

                brandBox.style.display = "block";
                ramBox.style.display = "none";
                typeBox.style.display = "none";
                accessoryBox.style.display = "block";

                brand.innerHTML = `
                    <option value="">-- Chọn hãng --</option>
                    <option value="Logitech">Logitech</option>
                    <option value="Razer">Razer</option>
                `;
            }
        }
        showFields();

            category.addEventListener("change", showFields);
    </script>    
</body>
</html>